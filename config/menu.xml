<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">

<menu id="root-menu" label="Linux Masaüstü">
  <item label="🖥️  Terminal (Ctrl+Alt+T)">
    <action name="Execute">
      <command>xterm -bg '#0e1117' -fg '#e2e8f0' -fa 'Monospace' -fs 12 -geometry 100x30 -title Terminal</command>
    </action>
  </item>
  <item label="📁  Dosya Gezgini">
    <action name="Execute"><command>thunar</command></action>
  </item>
  <item label="📝  Metin Editörü">
    <action name="Execute"><command>mousepad</command></action>
  </item>
  <item label="🌐  Firefox">
    <action name="Execute"><command>firefox</command></action>
  </item>
  <separator label="Geliştirici"/>
  <item label="🐍  Python 3 REPL">
    <action name="Execute">
      <command>xterm -bg '#0e1117' -fg '#e2e8f0' -fa 'Monospace' -fs 12 -title 'Python 3' -e python3</command>
    </action>
  </item>
  <item label="🟢  Node.js REPL">
    <action name="Execute">
      <command>xterm -bg '#0e1117' -fg '#e2e8f0' -fa 'Monospace' -fs 12 -title 'Node.js' -e node</command>
    </action>
  </item>
  <item label="📊  htop">
    <action name="Execute">
      <command>xterm -bg '#0e1117' -fg '#e2e8f0' -fa 'Monospace' -fs 12 -title 'htop' -e htop</command>
    </action>
  </item>
  <item label="📦  pip install ...">
    <action name="Execute">
      <command>xterm -bg '#0e1117' -fg '#e2e8f0' -fa 'Monospace' -fs 12 -title 'pip' -e bash -c 'echo "pip install komutu:"; read PKG; pip3 install $PKG; bash'</command>
    </action>
  </item>
  <item label="📦  apt install ...">
    <action name="Execute">
      <command>xterm -bg '#0e1117' -fg '#e2e8f0' -fa 'Monospace' -fs 12 -title 'apt' -e bash -c 'echo "apt install komutu:"; read PKG; apt-get install -y $PKG; bash'</command>
    </action>
  </item>
  <separator/>
  <item label="🔄  Openbox Yenile">
    <action name="Reconfigure"/>
  </item>
</menu>

</openbox_menu>
